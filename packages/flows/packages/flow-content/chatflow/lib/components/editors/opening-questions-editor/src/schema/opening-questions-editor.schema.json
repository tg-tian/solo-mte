{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "title": "开场白预置问题",
  "description": "设置用户进入对话时可以快速选择的问题列表",
  "items": {
    "type": "object",
    "title": "预置问题",
    "description": "单个预置问题配置",
    "properties": {
      "id": {
        "type": "string",
        "title": "问题ID",
        "description": "问题的唯一标识符",
        "pattern": "^[a-zA-Z0-9_-]+$",
        "minLength": 1,
        "maxLength": 100
      },
      "text": {
        "type": "string",
        "title": "问题内容",
        "description": "问题的具体文本内容",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "required": ["id", "text"],
    "additionalProperties": false
  },
  "minItems": 1,
  "maxItems": 20,
  "uniqueItems": true
}