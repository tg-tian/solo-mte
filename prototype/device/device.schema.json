{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ubml.gitee.io/device.schema.json",
  "title": "device",
  "description": "A IoT Device",
  "type": "object",
  "properties": {
    "properties": {
      "description": "",
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
