          }
        }
      }
    },
    "commands": {
      "description": "",
      "type": "array",
      "default": []
    },
    "events": {
      "description": "",
      "type": "array",
      "default": []
    }
  },
  "required": [
    "id",
    "type",
    "contents"
  ]
}